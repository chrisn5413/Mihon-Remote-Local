<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <uses-feature android:name="tachiyomi.extension" />

    <application
        android:allowBackup="false"
        android:label="@string/extension_name">

        <meta-data
            android:name="tachiyomi.extension.class"
            android:value=".CloudExtensionFactory" />

        <meta-data
            android:name="tachiyomi.extension.nsfw"
            android:value="0" />

        <activity
            android:name=".ui.ScanProgressActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Material.Light.NoActionBar" />

        <activity
            android:name=".ui.AddLibraryActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Material.Light.NoActionBar" />

        <activity
            android:name=".ui.LibrarySettingsActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Material.Light.NoActionBar" />

        <activity
            android:name=".ui.GlobalSettingsActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Material.Light.NoActionBar" />

    </application>
</manifest>
