<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <uses-feature android:name="tachiyomi.extension" />

    <application
        android:allowBackup="false"
        android:label="@string/extension_name">

        <meta-data
            android:name="tachiyomi.extension.class"
            android:value=".RemoteLibraryFactory" />

        <meta-data
            android:name="tachiyomi.extension.nsfw"
            android:value="0" />

        <!--
            Full class names required: namespace="eu.kanade.tachiyomi.extension" differs from
            applicationId="eu.kanade.tachiyomi.extension.remotelibrary", so AGP would expand ".ui.Foo"
            to the wrong package. Explicit names are always safe.
        -->
        <activity
            android:name="eu.kanade.tachiyomi.extension.remotelibrary.ui.ScanProgressActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Material.Light.NoActionBar" />

        <activity
            android:name="eu.kanade.tachiyomi.extension.remotelibrary.ui.AddLibraryActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Material.Light.NoActionBar" />

        <activity
            android:name="eu.kanade.tachiyomi.extension.remotelibrary.ui.LibrarySettingsActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Material.Light.NoActionBar" />

        <activity
            android:name="eu.kanade.tachiyomi.extension.remotelibrary.ui.GlobalSettingsActivity"
            android:exported="true"
            android:theme="@android:style/Theme.Material.Light.NoActionBar" />

    </application>
</manifest>
